						<key>Source</key>
						<string>Variable</string>
						<key>TimeOutAbortsMacro</key>
						<true/>
						<key>Variable</key>
						<string>AppListRaw</string>
						<key>WindowTitle</key>
						<string>Choose an App to Restart</string>
					</dict>
					<dict>
						<key>Action</key>
						<string>CaseSensitiveRegEx</string>
						<key>ActionUID</key>
						<integer>16318588</integer>
						<key>MacroActionType</key>
						<string>SearchReplace</string>
						<key>Replace</key>
						<string></string>
						<key>Search</key>
						<string>^•\s*</string>
						<key>Source</key>
						<string>Variable</string>
						<key>Variable</key>
						<string>SelectedApp</string>
						<key>Which</key>
						<string>All</string>
					</dict>
					<dict>
						<key>ActionUID</key>
						<integer>16318559</integer>
						<key>MacroActionType</key>
						<string>SetVariableToText</string>
						<key>Text</key>
						<string>%Variable%SelectedApp%</string>
						<key>Variable</key>
						<string>AppToRestart</string>
					</dict>
					<dict>
						<key>Action</key>
						<string>IgnoreCaseRegEx</string>
						<key>ActionUID</key>
						<integer>16318566</integer>
						<key>MacroActionType</key>
						<string>SearchReplace</string>
						<key>Replace</key>
						<string></string>
						<key>Search</key>
						<string> \(menu bar\)$</string>
						<key>Source</key>
						<string>Clipboard</string>
						<key>Which</key>
						<string>All</string>
					</dict>
					<dict>
						<key>ActionUID</key>
						<integer>16318569</integer>
						<key>DisplayKind</key>
						<string>None</string>
						<key>HonourFailureSettings</key>
						<true/>
						<key>IncludeStdErr</key>
						<false/>
						<key>IncludedVariables</key>
						<array>
							<string>9999</string>
						</array>
						<key>MacroActionType</key>
						<string>ExecuteAppleScript</string>
						<key>Path</key>
						<string></string>
						<key>Text</key>
						<string>tell application "Keyboard Maestro Engine"
	set appName to getvariable "AppToRestart"
end tell

-- Step 1: Try graceful quit
try
	tell application appName to quit
end try

delay 0.6

-- Step 2: Check if still running
tell application "System Events"
	set isRunning to exists (process appName)
end tell

set forced to false

-- Step 3: Force quit if needed
if isRunning then
	try
		do shell script "killall -9 " &amp; quoted form of appName
		set forced to true
	end try
end if

delay 0.4

-- Step 4: Relaunch
try
	do shell script "open -a " &amp; quoted form of appName
end try

-- Step 5: Feedback
if forced then
	display notification "Force-restarted " &amp; appName with title "App Restart"
else
	display notification "Restarted " &amp; appName with title "App Restart"
end if</string>
