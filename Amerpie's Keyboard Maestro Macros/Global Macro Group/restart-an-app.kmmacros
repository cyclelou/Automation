						</array>
						<key>MacroActionType</key>
						<string>ExecuteAppleScript</string>
						<key>Path</key>
						<string></string>
						<key>Text</key>
						<string>try	tell application "System Events"		set fgApps to name of (processes where background only is false)		set bgApps to name of (processes where background only is true)	end tell		set allFg to {}	set allBg to {}		-- Keyword blacklist (system + helpers + noise + your custom filters)	set blacklistKeywords to {"Notification", "Window", "Menu", "Monitor", "Manager", "Server", "Events", "Runner", "Daemon", "Dispatcher", "Extension", "Helper", "Agent", "Service", "Auxiliary", "Updater", "System", "Control", "Switcher", "Notifier", "Universal", "FinderSync", "Widget", "circled", "studentd", "osascript", "Engine", "Launcher", "SmartDelete", "_client", "storage"}		-- Whitelist: apps you always want to keep	set whitelist to {"Keyboard Maestro", "Stream Deck", "Default Folder X", "Bartender", "BetterTouchTool", "Rectangle", "CleanShot", "Raycast", "TextExpander", "Dropzone", "Hazel", "PopClip", "Supercharge", "Syncthing", "Tailscale", "Dato", "Clop", "MountMate", "Dropover", "AlDente", "NextDNS", "NameQuick", "kDrive"}		-- Process foreground apps	repeat with appName in fgApps		set appName to my normalizeName(appName as text)		if my isAllowed(appName, blacklistKeywords, whitelist) then			set end of allFg to appName		end if	end repeat		-- Process menu bar apps	repeat with appName in bgApps		set appName to my normalizeName(appName as text)		if my isAllowed(appName, blacklistKeywords, whitelist) then			set end of allBg to appName		end if	end repeat		-- Deduplicate	set allFg to my dedupe(allFg)	set allBg to my dedupe(allBg)		-- Sort	set allFg to my simpleSort(allFg)	set allBg to my simpleSort(allBg)		-- Build grouped list (simple + KM-safe)
set AppleScript's text item delimiters to linefeed

set fgText to allFg as text

set prefixedBg to {}
repeat with appName in allBg
	set end of prefixedBg to "• " &amp; appName
end repeat

set bgText to prefixedBg as text

set outputText to fgText &amp; linefeed &amp; "—" &amp; linefeed &amp; bgText

return outputText	on error errMsg number errNum	return "ERROR: " &amp; errMsg &amp; " (" &amp; errNum &amp; ")"end tryon normalizeName(appName)	-- Remove "Setapp" from names	set appName to my replaceText(" Setapp", "", appName)	set appName to my replaceText(" Setapp ", " ", appName)	return appNameend normalizeNameon isAllowed(appName, blacklistKeywords, whitelist)	-- Always allow whitelisted apps	repeat with w in whitelist		if appName contains (w as text) then return true	end repeat		-- Filter Apple/system processes	if appName starts with "com.apple." then return false		-- Filter by keyword blacklist	repeat with k in blacklistKeywords		if appName contains (k as text) then return false	end repeat		-- Filter cryptic daemon names (node, chronod, etc.)	if (count of characters of appName) &lt; 5 then return false		return trueend isAllowedon dedupe(theList)	set uniqueList to {}	repeat with a in theList		set a to a as text		if uniqueList does not contain a then set end of uniqueList to a	end repeat	return uniqueListend dedupeon simpleSort(theList)	set sortedList to {}	repeat with itemText in theList		set itemText to itemText as text				if (count of sortedList) is 0 then			set end of sortedList to itemText		else			set inserted to false			set i to 1						repeat with existing in sortedList				set existing to existing as text								if itemText comes before existing then					if i is 1 then						set sortedList to {itemText} &amp; sortedList					else						set sortedList to (items 1 thru (i - 1) of sortedList) &amp; {itemText} &amp; (items i thru -1 of sortedList)					end if					set inserted to true					exit repeat				end if								set i to i + 1			end repeat						if inserted is false then set end of sortedList to itemText		end if	end repeat	return sortedListend simpleSorton replaceText(findText, replaceText, sourceText)	set AppleScript's text item delimiters to findText	set textItems to every text item of sourceText	set AppleScript's text item delimiters to replaceText	set newText to textItems as text	set AppleScript's text item delimiters to ""	return newTextend replaceText</string>
						<key>TimeOutAbortsMacro</key>
