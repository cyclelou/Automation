            "BTTPredefinedActionType" : 284,
            "BTTPredefinedActionName" : "Transform & Replace Selection With Java Script",
            "BTTAdditionalActionData" : {
              "BTTClipboardTransformerExampleInput" : "",
              "BTTClipboardTransformerJS" : "async (clipboardContentString) => {\n  const text = clipboardContentString\n\n  const transformed = text\n    .trim()\n    \/\/ break camelCase \/ PascalCase into words\n    .replace(\/([a-z0-9])([A-Z])\/g, \"$1 $2\")\n    \/\/ replace non-alphanumeric with spaces\n    .replace(\/[^a-zA-Z0-9]+\/g, \" \")\n    .trim()\n    .toLowerCase()\n    .replace(\/\\s+\/g, \"_\")\n\n  return transformed\n}"
            },
            "BTTShortcutKeyboardType" : 0,
            "BTTShortcutKeyCode" : -1,
            "BTTOrder" : 1,
            "BTTAutoAdaptToKeyboardLayout" : 0
          }
        ]
