            "BTTTriggerClass" : "BTTTriggerTypeKeyboardShortcut",
            "BTTUUID" : "15A4808D-6116-45E9-9EE0-C5DB7EEE07C4",
            "BTTPredefinedActionType" : 284,
            "BTTPredefinedActionName" : "Transform & Replace Selection With Java Script",
            "BTTAdditionalActionData" : {
              "BTTClipboardTransformerExampleInput" : "",
              "BTTClipboardTransformerJS" : "async (clipboardContentString) => {\n  const text = clipboardContentString.toLowerCase()\n\n  const transformed = text\n    .split(\/\\s+\/)\n    .map(word => {\n      if (!word) return word\n      return word.charAt(0).toUpperCase() + word.slice(1)\n    })\n    .join(\" \")\n\n  return transformed\n}"
            },
            "BTTShortcutKeyboardType" : 0,
            "BTTShortcutKeyCode" : -1,
            "BTTOrder" : 1,
            "BTTAutoAdaptToKeyboardLayout" : 0
          }
        ]
      },
